# yaamon configuration — copy to config.yaml and customise.
# With Docker: mount at /etc/yaamon/config.yaml
# Any setting can be overridden with an env var: YAAMON_<SECTION>_<KEY>
#   e.g. YAAMON_DB_PATH=/var/lib/yaamon/yaamon.db

server:
  # Default port is 8080 so YAAMon can coexist with ASL3's Apache on port 80.
  # Change to 80 only if no other web server is running on this host.
  http_port: 8080
  https_port: 443
  redirect_http: true        # 301 redirect http → https when TLS is enabled
  # quic: true               # HTTP/3 (QUIC) over UDP — enabled by default when TLS is active.
  #                          # Set to false if UDP is blocked or behind a proxy (proxy handles QUIC).

  # bind_address: ""         # Listen on all interfaces (default).
  #                          # Set to 127.0.0.1 when running behind a reverse proxy (Apache/nginx)
  #                          # so YAAMon is not directly reachable from the network.
  # bind_address: 127.0.0.1

  # base_path: ""            # Serve YAAMon at the root path (default).
  #                          # Set when mounting under a sub-path via a reverse proxy.
  #                          # Must match the path prefix configured in Apache/nginx.
  #                          # Example: base_path: /yaamon → accessible at http://host/yaamon/
  # base_path: /yaamon

  # allow_public_plaintext: false   # Safety guard: YAAMon refuses to start when tls.mode is
  #                                 # disabled and the bound address is publicly routable (non-RFC-1918).
  #                                 # Set to true only if you understand the risk (credentials in the
  #                                 # clear) and have an external layer handling security.
  # allow_public_plaintext: true

tls:
  mode: disabled             # disabled | self_signed | provided | acme
  # cert_file: /etc/yaamon/fullchain.pem   # required for mode: provided
  # key_file:  /etc/yaamon/privkey.pem     # required for mode: provided
  # acme_domain: my.example.com           # required for mode: acme
  # acme_cache_dir: /etc/yaamon/acme

db:
  # deb install: /var/lib/yaamon/yaamon.db (FHS 3.0 — mutable state in /var/lib)
  # Docker:      override with YAAMON_DB_PATH=/var/lib/yaamon/yaamon.db and mount a volume at /var/lib/yaamon
  path: /var/lib/yaamon/yaamon.db

astdb:
  # Path to the AllStarLink node database file (pipe-delimited, downloaded from
  # allmondb.allstarlink.org). YAAMon reads this file to fill in callsign,
  # description, and location for nodes not manually configured.
  #
  # Standard Asterisk install: /var/lib/asterisk/astdb.txt  (default)
  # Docker (no Asterisk):      /var/lib/yaamon/astdb.txt
  #   — set via env var: YAAMON_ASTDB_PATH=/var/lib/yaamon/astdb.txt
  path: /var/lib/asterisk/astdb.txt
  #
  # update: true (default) — download a fresh copy on startup and every hour.
  # update: false          — read the existing file only; no network requests.
  #   Useful when Asterisk is running on the same host and already keeps the file
  #   current, or when the host has no internet access.
  update: true

log:
  level: info                # debug | info | warn | error

ui:
  # Footer left side — shown on every page.
  footer_text: "Yet Another Allstarlink MONitor (and favorites)"
  # footer_url: https://github.com/jchonig/allstar-yaamon   # GitHub icon link next to footer_text

  # Footer right side — attribution link.
  footer_attribution: N2VLV
  footer_attribution_url: https://n2vlv.net

# commands: Node command menu shown in the dashboard Functions dropdown.
# Omit this section to use the built-in defaults.
# Each entry needs: name, cmd ({node} is replaced with the node number), and role.
# Commands that produce output display it in a modal; others show a toast.
# commands:
#   commands:
#     # --- Announcements (group: announce) ---
#     - name:  "Say Time of Day"
#       cmd:   "rpt cmd {node} status 12 xxx"
#       role:  readwrite
#       group: announce
#     - name:  "Force ID"
#       cmd:   "rpt cmd {node} status 11 xxx"
#       role:  readwrite
#       group: announce
#
#     # --- Linking (group: link) ---
#     - name:  "Reconnect"
#       cmd:   "rpt cmd {node} ilink 16"
#       role:  readwrite
#       group: link
#     # Example with a user-supplied argument:
#     # - name:  "Link to Node"
#     #   cmd:   "rpt cmd {node} ilink 3 {target}"
#     #   role:  readwrite
#     #   group: link
#     #   args:
#     #     - name:  target
#     #       label: "Target Node Number"
#     #       type:  node_number
#
#     # --- Status / information (group: status) ---
#     - name:  "Show Node Status"
#       cmd:   "rpt stats {node}"
#       role:  readwrite
#       group: status
#     - name:  "Show Link Status"
#       cmd:   "rpt lstats {node}"
#       role:  readwrite
#       group: status
#     - name:  "Show IAX Registry"
#       cmd:   "iax2 show registry"
#       role:  readwrite
#       group: status
#     - name:  "Show IAX Channels"
#       cmd:   "iax2 show channels"
#       role:  readwrite
#       group: status
#     - name:  "Show Network Status"
#       cmd:   "iax2 show netstats"
#       role:  readwrite
#       group: status
#     - name:  "Show Uptime"
#       cmd:   "core show uptime"
#       role:  readwrite
#       group: status
#
#     # --- Telemetry (group: telemetry) ---
#     - name:  "Local Telemetry Enable"
#       cmd:   "rpt cmd {node} cop 33 xxx"
#       role:  readwrite
#       group: telemetry
#     - name:  "Local Telemetry Disable"
#       cmd:   "rpt cmd {node} cop 34 xxx"
#       role:  readwrite
#       group: telemetry
#     - name:  "Local Telemetry On Demand"
#       cmd:   "rpt cmd {node} cop 35 xxx"
#       role:  readwrite
#       group: telemetry
#
#     # --- System control — admin only (group: system) ---
#     - name:  "Enable System"
#       cmd:   "rpt cmd {node} cop 2 xxx"
#       role:  admin
#       group: system
#     - name:  "Disable System"
#       cmd:   "rpt cmd {node} cop 3 xxx"
#       role:  admin
#       group: system
#     - name:  "Enable Linking"
#       cmd:   "rpt cmd {node} cop 11 xxx"
#       role:  admin
#       group: system
#     - name:  "Disable Linking"
#       cmd:   "rpt cmd {node} cop 12 xxx"
#       role:  admin
#       group: system
#     - name:  "Enable Autopatch"
#       cmd:   "rpt cmd {node} cop 9 xxx"
#       role:  admin
#       group: system
#     - name:  "Disable Autopatch"
#       cmd:   "rpt cmd {node} cop 10 xxx"
#       role:  admin
#       group: system
#     - name:  "Enable User Functions"
#       cmd:   "rpt cmd {node} cop 17 xxx"
#       role:  admin
#       group: system
#     - name:  "Disable User Functions"
#       cmd:   "rpt cmd {node} cop 18 xxx"
#       role:  admin
#       group: system
#     - name:  "Toggle Test Tone"
#       cmd:   "rpt cmd {node} cop 4 1"
#       role:  admin
#       group: system
#     - name:  "System State 0 (normal)"
#       cmd:   "rpt cmd {node} cop 14 0"
#       role:  admin
#       group: system
#     - name:  "System State 1 (rpt only)"
#       cmd:   "rpt cmd {node} cop 14 1"
